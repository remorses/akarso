{
  "name": "akarso",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI for posting and replying across 14 social platforms via Akarso.",
  "bin": "dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "typecheck": "tsc",
    "cli": "sigillo run -- tsx src/cli.ts",
    "test": "vitest run --no-watch",
    "generate-docs": "tsx scripts/generate-docs.ts",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build"
  },
  "keywords": [
    "social-api",
    "social-media",
    "cli",
    "scheduling",
    "posting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/akarso",
    "directory": "cli"
  },
  "homepage": "https://github.com/remorses/akarso",
  "bugs": "https://github.com/remorses/akarso/issues",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@goke/mcp": "^0.0.11",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.2.8",
    "goke": "^6.13.0",
    "string-dedent": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "spiceflow": "1.26.0-rsc.7"
  },
  "devDependencies": {
    "akarso-website": "workspace:^"
  }
}
