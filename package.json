{
  "name": "akarso",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI for posting and replying across 14 social platforms via Zernio API.",
  "bin": "dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "typecheck": "tsc",
    "cli": "sigillo run -- tsx src/cli.ts",
    "test": "vitest run --no-watch",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build"
  },
  "keywords": [
    "zernio",
    "social-media",
    "cli",
    "scheduling",
    "posting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/akarso",
    "directory": "cli"
  },
  "homepage": "https://github.com/remorses/akarso",
  "bugs": "https://github.com/remorses/akarso/issues",
  "license": "MIT",
  "dependencies": {
    "@zernio/node": "^0.2.88",
    "goke": "^6.9.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.6.0"
  }
}
